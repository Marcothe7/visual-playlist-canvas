# Server-side secrets (NOT VITE_ prefixed — never exposed to browser)
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Client-side (VITE_ prefixed — intentionally in browser bundle for OAuth URL)
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id

# Your app's public URL — used as the Spotify OAuth redirect_uri
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app
VITE_APP_URL=http://localhost:3000
